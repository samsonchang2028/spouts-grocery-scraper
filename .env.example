# Supabase project URL (found in your Supabase project settings under API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key (found in your Supabase project settings under API)
# WARNING: This key bypasses Row Level Security. Never expose it in client-side code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# UUID of the pre-seeded Sprouts store row in the stores table
# Run: SELECT id FROM stores WHERE name = 'Sprouts' LIMIT 1;
SPROUTS_STORE_ID=your-sprouts-store-uuid-here

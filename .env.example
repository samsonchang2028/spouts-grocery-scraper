# Supabase project URL (found in your Supabase project settings under API)
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase service role key (found in your Supabase project settings under API)
# WARNING: This key bypasses Row Level Security. Never expose it in client-side code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# UUID of the pre-seeded Sprouts store row in the stores table
# Run: SELECT id FROM stores WHERE name = 'Sprouts' LIMIT 1;
SPROUTS_STORE_ID=your-sprouts-store-uuid-here

# UUID of the pre-seeded Smart & Final store row in the stores table
# Run: SELECT id FROM stores WHERE name = 'Smart & Final' LIMIT 1;
SMART_AND_FINAL_STORE_ID=your-smartandfinal-store-uuid-here

# UUID of the pre-seeded Grocery Outlet store row in the stores table
# Run: SELECT id FROM stores WHERE name = 'Grocery Outlet' LIMIT 1;
GROCERY_OUTLET_STORE_ID=your-groceryoutlet-store-uuid-here

# UUID of the California Fresh Market store row in the stores table
# Run: SELECT id FROM stores WHERE name = 'California Fresh Market' LIMIT 1;
CAL_FRESH_STORE_ID=your-calfresh-store-uuid-here

# UUID of the Trader Joe's store row in the stores table
# Run: SELECT id FROM stores WHERE name = 'Trader Joe''s' LIMIT 1;
TRADER_JOES_STORE_ID=your-traderjoes-store-uuid-here